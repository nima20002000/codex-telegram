# Required: create a bot with @BotFather and paste its token here.
TELEGRAM_BOT_TOKEN=

# Strongly recommended: comma-separated Telegram numeric user IDs allowed to use the bot.
# Leave empty only for a private test bot where anyone who can reach the bot may run Codex.
TELEGRAM_ALLOWED_USERS=

# Optional: restrict chats too. Useful if the bot is added to groups.
TELEGRAM_ALLOWED_CHATS=

# Where Codex should work.
CODEX_WORKDIR=$HOME/Desktop

# Keep bridge runtime files in this repo even when Codex works elsewhere.
HERMES_TELEGRAM_STATE_DIR=$HOME/Desktop/hermes-telegram/.hermes-telegram

# Codex CLI settings.
# Use an absolute path for systemd if your interactive shell uses nvm/asdf/etc.
CODEX_COMMAND=codex
CODEX_SANDBOX=workspace-write
CODEX_TIMEOUT_SECONDS=1800
# CODEX_MODEL=
# CODEX_PROFILE=
# CODEX_EXTRA_ARGS=

# Telegram polling and response behavior.
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_REQUEST_TIMEOUT_SECONDS=45
MAX_TELEGRAM_RESPONSE_CHARS=12000
SESSION_HISTORY_TURNS=8
